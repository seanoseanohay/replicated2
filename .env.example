# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bundleanalyzer

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bundleanalyzer
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=bundles

# App settings
MAX_BUNDLE_SIZE_MB=500
APP_ENV=development
SECRET_KEY=dev-secret-key-change-in-prod

# AI (optional — set AI_ENABLED=true to activate)
ANTHROPIC_API_KEY=
AI_ENABLED=false
AI_MODEL=claude-opus-4-6

CORS_ALLOWED_ORIGINS=*
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_AI=20/minute

# Frontend (used at build time by Vite)
VITE_API_URL=http://localhost:8000
